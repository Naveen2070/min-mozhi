thoguthi SyncPulse {
    thudippu clk_src
    thudippu clk_dst
    meettamai rst

    ulleedu src_pulse: bit
    pathivedu src_reg: bit = 0
    veliyeedu dst_pulse: bit

    pothu yetram(clk_src) {
        src_reg <- src_pulse
    }

    kambi dst_pulse_w: bit = othisai.pulse(src_reg, clk_src, clk_dst)

    dst_pulse = dst_pulse_w
}
