// Min-Mozhi example (Tanglish flavor — same grammar, only the keywords change): comparator with an if-expression.
// A wire-driving `if` must have an `else` — both branches always exist,
// so the output is always driven.

thoguthi Comparator(WIDTH: int = 8) {
  ulleedu  a: bits[WIDTH]
  ulleedu  b: bits[WIDTH]

  veliyeedu eq:  bit
  veliyeedu gt:  bit
  veliyeedu max: bits[WIDTH]

  eq  = a == b
  gt  = a > b
  max = enil a > b { a } illaiyenil { b }
}
