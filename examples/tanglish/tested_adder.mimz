// Min-Mozhi example (Tanglish flavor — same grammar, only the keywords change): combinational adder
// `test` blocks do not emit hardware, but can be exported to standard Verilog
// testbenches using `mimz compile --emit-testbench`

thoguthi Adder(WIDTH: int = 8) {
  ulleedu  a: bits[WIDTH]
  ulleedu  b: bits[WIDTH]
  veliyeedu sum: bits[WIDTH + 1]

  sum = a + b
}

sodhanai "adder works" kaaga Adder(WIDTH: 4) {
  a = 5
  b = 10
  uruthisei sum == 15
}
