// Min-Mozhi example (Tanglish flavor — same grammar, only the keywords change):
// file-level const referenced inside a function body.

maarili SCALE: int = 3

saarbu scaled(a: bits[8]) -> bits[8] {
  a >> SCALE
}

thoguthi Scaled {
  ulleedu a: bits[8]
  veliyeedu result: bits[8]
  result = scaled(a)
}
