// Min-Mozhi example (Tanglish flavor — same grammar, only the keywords change): 4-way multiplexer.
// `match` on the select must cover every case — a missing arm is a
// compile error, so no inferred latches.

thoguthi Mux4(WIDTH: int = 8) {
  ulleedu  sel: bits[2]
  ulleedu  a: bits[WIDTH]
  ulleedu  b: bits[WIDTH]
  ulleedu  c: bits[WIDTH]
  ulleedu  d: bits[WIDTH]
  veliyeedu y: bits[WIDTH]

  y = thernthedu sel {
    0b00 => a
    0b01 => b
    0b10 => c
    0b11 => d
  }
}
