// Min-Mozhi example (Tanglish flavor — same grammar, only the keywords change): dual-edge pipeline.
// A posedge register `a` captures the input; a negedge register `b` captures
// `a` half a period later (same period) — `on rise` and `on fall` both appear.

thoguthi DualEdge {
  thudippu clk
  meettamai rst

  ulleedu  d: bits[8]
  veliyeedu q: bits[8]

  pathivedu a: bits[8] = 0
  pathivedu b: bits[8] = 0

  pothu yetram(clk) {
    a <- d
  }
  pothu irakkam(clk) {
    b <- a
  }

  q = b
}
