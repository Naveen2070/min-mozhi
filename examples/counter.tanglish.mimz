// Min-Mozhi example: the same counter in the Tanglish flavor.
// Same grammar, same operators, same types — only keywords change.
// `mimz translate counter.mimz --to tanglish` produces this file.

thoguthi Counter(WIDTH: int = 8) {
  kadigaram clk
  meetamai rst

  veli count: bits[WIDTH]

  nilai value: bits[WIDTH] = 0

  pothu yetram(clk) {
    value <- value +% 1
  }

  count = value
}
