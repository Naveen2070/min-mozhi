// Min-Mozhi example (Tamil flavor — same grammar, only the keywords change): bit replication `{N{x}}`.
// `{2{a}}` is `{a, a}`; the count is compile-time, like concatenation.

தொகுதி Replicate {
  உள்ளீடு  a: bits[4]

  வெளியீடு doubled: bits[8]
  வெளியீடு tripled: bits[12]

  doubled = {2{a}}
  tripled = {3{a}}
}
