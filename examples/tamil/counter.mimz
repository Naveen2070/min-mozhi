// Min-Mozhi example (Tamil flavor — same grammar, only the keywords change): free-running counter
// `reg ... = 0` declares the reset value (mandatory — no uninitialized state).
// `+%` is wrapping add: same width, wraps on overflow — on purpose, visibly.

தொகுதி Counter(WIDTH: int = 8) {
  துடிப்பு clk
  மீட்டமை rst

  வெளியீடு count: bits[WIDTH]

  பதிவேடு value: bits[WIDTH] = 0

  போது ஏற்றம்(clk) {
    value <- value +% 1
  }

  count = value
}
