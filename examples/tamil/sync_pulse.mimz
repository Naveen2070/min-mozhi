தொகுதி SyncPulse {
    துடிப்பு clk_src
    துடிப்பு clk_dst
    மீட்டமை rst

    உள்ளீடு src_pulse: bit
    பதிவேடு src_reg: bit = 0
    வெளியீடு dst_pulse: bit

    போது ஏற்றம்(clk_src) {
        src_reg <- src_pulse
    }

    கம்பி dst_pulse_w: bit = ஒத்திசை.pulse(src_reg, clk_src, clk_dst)

    dst_pulse = dst_pulse_w
}
