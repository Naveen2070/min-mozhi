// Min-Mozhi example (Tamil flavor — same grammar, only the keywords change): comparator with an if-expression.
// A wire-driving `if` must have an `else` — both branches always exist,
// so the output is always driven.

தொகுதி Comparator(WIDTH: int = 8) {
  உள்ளீடு  a: bits[WIDTH]
  உள்ளீடு  b: bits[WIDTH]

  வெளியீடு eq:  bit
  வெளியீடு gt:  bit
  வெளியீடு max: bits[WIDTH]

  eq  = a == b
  gt  = a > b
  max = எனில் a > b { a } இல்லையெனில் { b }
}
