// Min-Mozhi example (Tamil flavor — same grammar, only the keywords change): combinational adder
// `+` is lossless: bits[W] + bits[W] -> bits[W+1], so the carry is kept.

தொகுதி Adder(WIDTH: int = 8) {
  உள்ளீடு  a: bits[WIDTH]
  உள்ளீடு  b: bits[WIDTH]
  வெளியீடு sum: bits[WIDTH + 1]

  sum = a + b
}
