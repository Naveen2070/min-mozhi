// Min-Mozhi example (Tamil flavor — same grammar, only the keywords change): combinational adder
// `test` blocks do not emit hardware, but can be exported to standard Verilog
// testbenches using `mimz compile --emit-testbench`

தொகுதி Adder(WIDTH: int = 8) {
  உள்ளீடு  a: bits[WIDTH]
  உள்ளீடு  b: bits[WIDTH]
  வெளியீடு sum: bits[WIDTH + 1]

  sum = a + b
}

சோதனை "adder works" க்காக Adder(WIDTH: 4) {
  a = 5
  b = 10
  உறுதிசெய் sum == 15
}
