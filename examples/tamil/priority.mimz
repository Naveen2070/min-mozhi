// Min-Mozhi example (Tamil flavor — same grammar, only the keywords change): priority decoder with don't-care `match` patterns.
// `0b1??` matches any value whose high bit is 1 — the casez idiom. The `_`
// arm is required (masked patterns do not prove exhaustiveness on their own).

தொகுதி Priority {
  உள்ளீடு  req: bits[3]

  வெளியீடு grant: bits[2]

  grant = தேர்ந்தெடு req {
    0b1?? => 0b11
    0b01? => 0b10
    0b001 => 0b01
    _     => 0b00
  }
}
