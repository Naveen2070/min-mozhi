// Min-Mozhi example (Tamil flavor — same grammar, only the keywords change):
// narrow-local inference in function bodies.

சார்பு wrap_mul(a: bits[8], b: bits[8]) -> bits[8] {
  let p = a *% b
  p
}

தொகுதி WrapMul {
  உள்ளீடு a: bits[8]
  உள்ளீடு b: bits[8]
  வெளியீடு result: bits[8]
  result = wrap_mul(a, b)
}
