// Min-Mozhi example (Tamil flavor — same grammar, only the keywords change) library: one-bit full adder. Imported by
// chained.mimz via the dotted path `lib.full_adder`.

தொகுதி FullAdder {
  உள்ளீடு  a:    bit
  உள்ளீடு  b:    bit
  உள்ளீடு  cin:  bit

  வெளியீடு sum:  bit
  வெளியீடு cout: bit

  sum  = a ^ b ^ cin
  cout = (a & b) | (cin & (a ^ b))
}
