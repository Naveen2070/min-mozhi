// Min-Mozhi example (mixed flavors — English, Tanglish, and Tamil keywords in one file; mixing freely is the migration path): user-defined combinational function
// Declares `mac(a, b) = a * b` as a reusable combinational block.

fn mac(a: bits[8], b: bits[8]) -> bits[16] {
  a * b
}

thoguthi Mac {
  ulleedu a: bits[8]
  உள்ளீடு b: bits[8]
  out result: bits[16]
  result = mac(a, b)
}
