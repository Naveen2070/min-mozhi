// Demonstrates: const if for compile-time conditional signal routing
module DebugWrapper {
  maarili DEBUG: int = 0

  in  data_in: bits[8]
  out data_out: bits[8]
  out dbg_out:  bits[8]

  maarili எனில் (DEBUG) {
    dbg_out = data_in
  } இல்லையெனில் {
    dbg_out = 0
  }

  data_out = data_in
}
