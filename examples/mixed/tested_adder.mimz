// Min-Mozhi example (mixed flavors): combinational adder
// `test` blocks do not emit hardware, but can be exported to standard Verilog
// testbenches using `mimz compile --emit-testbench`

module Adder(WIDTH: int = 8) {
  ulleedu  a: bits[WIDTH]
  உள்ளீடு  b: bits[WIDTH]
  out sum: bits[WIDTH + 1]

  sum = a + b
}

sodhanai "adder works" for Adder(WIDTH: 4) {
  a = 5
  b = 10
  உறுதிசெய் sum == 15
}
