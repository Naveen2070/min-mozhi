// Min-Mozhi example (mixed flavors — English, Tanglish, and Tamil keywords in one file; mixing freely is the migration path): combinational adder
// `+` is lossless: bits[W] + bits[W] -> bits[W+1], so the carry is kept.

module Adder(WIDTH: int = 8) {
  ulleedu  a: bits[WIDTH]
  உள்ளீடு  b: bits[WIDTH]
  out sum: bits[WIDTH + 1]

  sum = a + b
}
