// Min-Mozhi example (mixed flavors — English, Tanglish, and Tamil keywords in one file; mixing freely is the migration path): a counter with an asynchronous reset.
// `async reset` clears the register the instant `rst` is asserted, not at the
// next clock edge. Reset is active-high.

module ACounter {
  thudippu clk
  async மீட்டமை rst

  veliyeedu count: bits[8]

  பதிவேடு value: bits[8] = 0

  போது rise(clk) {
    value <- value +% 1
  }

  count = value
}
