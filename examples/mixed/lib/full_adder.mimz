// Min-Mozhi example (mixed flavors — English, Tanglish, and Tamil keywords in one file; mixing freely is the migration path) library: one-bit full adder. Imported by
// chained.mimz via the dotted path `lib.full_adder`.

module FullAdder {
  ulleedu  a:    bit
  உள்ளீடு  b:    bit
  in  cin:  bit

  veliyeedu sum:  bit
  வெளியீடு cout: bit

  sum  = a ^ b ^ cin
  cout = (a & b) | (cin & (a ^ b))
}
