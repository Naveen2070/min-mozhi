// Min-Mozhi example: a priority decoder using don't-care `match` patterns.
// `0b1??` matches any value whose high bit is 1 — the casez idiom. The `_`
// arm is required (masked patterns do not prove exhaustiveness on their own).

module Priority {
  in  req: bits[3]

  out grant: bits[2]

  grant = match req {
    0b1?? => 0b11
    0b01? => 0b10
    0b001 => 0b01
    _     => 0b00
  }
}
