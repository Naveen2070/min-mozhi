// Min-Mozhi example: 4-way multiplexer.
// `match` on the select must cover every case — a missing arm is a
// compile error, so no inferred latches.

module Mux4(WIDTH: int = 8) {
  in  sel: bits[2]
  in  a: bits[WIDTH]
  in  b: bits[WIDTH]
  in  c: bits[WIDTH]
  in  d: bits[WIDTH]
  out y: bits[WIDTH]

  y = match sel {
    0b00 => a
    0b01 => b
    0b10 => c
    0b11 => d
  }
}
