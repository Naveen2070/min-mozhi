// Min-Mozhi example: LED blinker — divide the clock down with a counter
// and toggle the output with `^` each time it wraps.

module Blinker(LIMIT: int = 50000000) {
  clock clk
  reset rst

  out led: bit

  reg cnt:   bits[26] = 0
  reg state: bit      = 0

  on rise(clk) {
    if cnt == LIMIT {
      cnt   <- 0
      state <- state ^ 1
    } else {
      cnt <- cnt +% 1
    }
  }

  led = state
}
