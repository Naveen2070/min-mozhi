// Code-order twin of match.thamizh.mimz (spec/04, Phase 1.8). Self-contained
// (no `import`) so the same-Verilog oracle compares two fixtures directly. The
// match head leads: `y = thernthedu op { … }`.
thoguthi Alu(WIDTH: int = 8) {
  ulleedu  a:  bits[WIDTH]
  ulleedu  b:  bits[WIDTH]
  ulleedu  op: bits[2]
  veliyeedu y:  bits[WIDTH]

  y = thernthedu op {
    0b00 => a +% b
    0b01 => a -% b
    0b10 => a & b
    0b11 => a | b
  }
}
