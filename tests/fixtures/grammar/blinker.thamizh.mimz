ilakkanam thamizh

thoguthi Blinker(LIMIT: int = 50000000) {
  thudippu clk
  meettamai rst
  veliyeedu led: bit
  pathivedu cnt: bits[26] = 0
  pathivedu state: bit = 0
  yetram(clk) pothu {
    (cnt == LIMIT) enil {
      cnt <- 0
      state <- state ^ 1
    } illaiyenil {
      cnt <- cnt +% 1
    }
  }
  led = state
}
