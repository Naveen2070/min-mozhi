இலக்கணம் தமிழ்

தொகுதி TrafficLight {
  துடிப்பு clk
  மீட்டமை rst
  வெளியீடு red: bit
  வெளியீடு yellow: bit
  வெளியீடு green: bit
  வகை State { Red, Green, Yellow }
  பதிவேடு state: State = State.Red
  பதிவேடு timer: bits[8] = 0
  ஏற்றம்(clk) போது {
    (timer == 0) எனில் {
      state <- state தேர்ந்தெடு {
        State.Red => State.Green
        State.Green => State.Yellow
        State.Yellow => State.Red
      }
      timer <- state தேர்ந்தெடு {
        State.Red => 50
        State.Green => 40
        State.Yellow => 10
      }
    } இல்லையெனில் {
      timer <- timer -% 1
    }
  }
  red = state == State.Red
  yellow = state == State.Yellow
  green = state == State.Green
}
