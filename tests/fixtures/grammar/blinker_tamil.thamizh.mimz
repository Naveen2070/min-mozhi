இலக்கணம் தமிழ்

தொகுதி Blinker(LIMIT: int = 50000000) {
  துடிப்பு clk
  மீட்டமை rst
  வெளியீடு led: bit
  பதிவேடு cnt: bits[26] = 0
  பதிவேடு state: bit = 0
  ஏற்றம்(clk) போது {
    (cnt == LIMIT) எனில் {
      cnt <- 0
      state <- state ^ 1
    } இல்லையெனில் {
      cnt <- cnt +% 1
    }
  }
  led = state
}
