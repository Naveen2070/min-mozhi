---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
---

<Base
  title="Not found — Min-Mozhi"
  description="That page doesn't exist. Browse the Min-Mozhi guide and language spec, or try the in-browser playground."
>
  <Nav />
  <main class="mx-auto max-w-6xl px-4 py-24 text-center">
    <p class="spark-gradient bg-clip-text text-7xl font-bold text-transparent">
      404
    </p>
    <h1 class="fg mt-4 text-2xl font-semibold">That signal didn't resolve.</h1>
    <p class="fg-muted mt-3">
      Try the <a href="/guide/01-getting-started">docs</a> or head back
      <a href="/">home</a>.
    </p>
  </main>
</Base>
