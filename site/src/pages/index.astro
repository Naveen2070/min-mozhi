---
import { readFileSync } from "node:fs";
import path from "node:path";
import { Code } from "astro:components";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.tsx";
import SafeByDefault from "../components/features/SafeByDefault.tsx";
import BuiltToTeach from "../components/features/BuiltToTeach.tsx";
import Trilingual from "../components/features/Trilingual.tsx";

// repo root is the parent of site/ (cwd during astro build/dev). Plain fs read,
// not `new URL(..., import.meta.url)` — Vite would treat that as an asset import.
const repoRoot = path.resolve(process.cwd(), "..");
const counter = readFileSync(
  path.join(repoRoot, "examples/english/counter.mimz"),
  "utf-8",
).trim();

const mimzGrammar = JSON.parse(
  readFileSync(
    path.join(repoRoot, "editors/vscode/syntaxes/mimz.tmLanguage.json"),
    "utf-8",
  ),
);
const mimzLang = { ...mimzGrammar, name: "mimz" };
const shikiThemes = { light: "github-light", dark: "github-dark" } as const;

const highlights = [
  {
    title: "Modern & safe by default",
    body: "Familiar Go/TypeScript-style syntax, checked like Rust. The compiler catches the classic hardware footguns — inferred latches, silent width truncation, multiple drivers, uninitialized registers — before they reach Verilog, and reports each as a clear, actionable error.",
  },
  {
    title: "Built to teach",
    body: "A small, focused language with one obvious way to do things. Its diagnostics don't just flag an error — they explain what is wrong, why it is unsafe in hardware, and how to fix it, so learners build the right mental model as they go.",
  },
  {
    title: "Trilingual, Tamil-first",
    body: "Write the same module with English, Tanglish, or Tamil keywords — one grammar, one compiler. Switch flavors freely and the emitted Verilog stays byte-identical, so a design reads natively in your language without changing what it builds.",
  },
];

// JSON-LD: describe the project as open-source software for richer search results.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: "Min-Mozhi",
  alternateName: "மின்மொழி",
  description:
    "A modern, safe-by-default hardware description language — built to teach digital design, and the first Tamil-rooted HDL.",
  url: "https://mimz.naveenr.in",
  codeRepository: "https://github.com/Naveen2070/min-mozhi",
  programmingLanguage: ["Rust", "Verilog"],
  license: "https://spdx.org/licenses/MIT.html",
  author: { "@type": "Person", name: "Naveen R" },
};
---

<Base>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <Nav />

  <main class="mx-auto max-w-6xl px-4">
    <!-- Hero -->
    <section class="grid items-center gap-10 py-16 lg:grid-cols-2 lg:py-24">
      <div>
        <p class="fg-muted mb-4 text-sm font-medium">
          <span class="ff-tamil" lang="ta">மின்மொழி</span> · the language of electricity
        </p>
        <h1
          class="fg text-4xl font-bold leading-tight tracking-tight sm:text-5xl"
        >
          A modern, <span class="spark-gradient bg-clip-text text-transparent"
            >safe-by-default</span
          > hardware description language.
        </h1>
        <p class="fg-muted mt-5 max-w-xl text-lg">
          Built to teach digital design — and the first Tamil-rooted HDL. Reads
          like Go/TypeScript, safe like Rust, speaks English, Tanglish, and
          Tamil.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="/guide/01-getting-started"
            class="btn-primary rounded-md px-5 py-2.5 text-sm font-semibold no-underline"
          >
            Get started
          </a>
          <a
            href="https://github.com/Naveen2070/min-mozhi"
            class="btn-outline rounded-md border px-5 py-2.5 text-sm font-semibold no-underline"
          >
            GitHub
          </a>
          <a
            href="/playground"
            class="btn-outline rounded-md border px-5 py-2.5 text-sm font-semibold no-underline"
          >
            Playground
          </a>
        </div>
      </div>

      <!-- Oscilloscope: the clock waveform an HDL describes -->
      <div class="bd bg-soft overflow-hidden rounded-xl border">
        <div
          class="bd fg-muted flex items-center justify-between border-b px-4 py-2 text-xs"
        >
          <span class="ff-mono">clk · rising edge</span>
          <span
            class="spark-gradient bg-clip-text font-semibold text-transparent"
            >live</span
          >
        </div>
        <Hero client:visible />
      </div>
    </section>

    <!-- Code sample -->
    <section class="pb-16">
      <p class="fg-muted mb-3 text-sm">
        A counter in Min-Mozhi — <code class="ff-mono">counter.mimz</code> compiles
        to synthesizable Verilog and simulates to that waveform.
      </p>
      <Code code={counter} lang={mimzLang} themes={shikiThemes} />
    </section>

    <!-- Why — three alternating feature rows with reveal-on-scroll art -->
    <section class="bd border-t py-16">
      <div class="flex flex-col gap-14 lg:gap-20">
        <!-- Row 1 — illustration left, text right -->
        <div class="grid items-center gap-8 lg:grid-cols-2">
          <div class="bd bg-soft order-last rounded-xl border p-5 lg:order-first">
            <SafeByDefault client:visible />
          </div>
          <div class="lg:order-last">
            <h2 class="fg mb-3 text-xl font-semibold">{highlights[0].title}</h2>
            <p class="fg-muted text-sm leading-relaxed">{highlights[0].body}</p>
          </div>
        </div>

        <!-- Row 2 — text left, illustration right -->
        <div class="grid items-center gap-8 lg:grid-cols-2">
          <div>
            <h2 class="fg mb-3 text-xl font-semibold">{highlights[1].title}</h2>
            <p class="fg-muted text-sm leading-relaxed">{highlights[1].body}</p>
          </div>
          <div class="bd bg-soft rounded-xl border p-5">
            <BuiltToTeach client:visible />
          </div>
        </div>

        <!-- Row 3 — illustration left, text right -->
        <div class="grid items-center gap-8 lg:grid-cols-2">
          <div class="bd bg-soft order-last rounded-xl border p-5 lg:order-first">
            <Trilingual client:visible />
          </div>
          <div class="lg:order-last">
            <h2 class="fg mb-3 text-xl font-semibold">{highlights[2].title}</h2>
            <p class="fg-muted text-sm leading-relaxed">{highlights[2].body}</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
