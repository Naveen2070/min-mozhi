---
import { getCollection } from "astro:content";
import { docLabel, sortDocs } from "../lib/docs";

interface Props {
  current: string; // e.g. "guide/04-signals"
}
const { current } = Astro.props;

const allGuide = await getCollection("guide");
const guideMain = sortDocs(allGuide.filter((d: any) => !d.id.startsWith("stdlib/")));
const stdlibAll = sortDocs(allGuide.filter((d: any) => d.id.startsWith("stdlib/")));
const stdlibMain = stdlibAll.filter((d: any) => d.id.toLowerCase() !== "stdlib/readme");

const spec = sortDocs(await getCollection("spec"));

const sections = [
  { title: "Guide", base: "guide", entries: guideMain, hasOverview: true },
  { title: "Standard Library", base: "guide", overviewHref: "guide/stdlib/readme", entries: stdlibMain, hasOverview: true },
  { title: "Spec", base: "spec", entries: spec, hasOverview: true },
];
---

<nav aria-label="Documentation" class="text-sm">
  {
    sections.map((section) => {
      const overviewPath = section.overviewHref || section.base;
      return (
      <details class="group mb-7" open>
        <summary class="fg-muted mb-2 text-xs font-semibold uppercase tracking-wider cursor-pointer select-none flex items-center justify-between hover:opacity-80 transition-opacity" style="list-style: none;">
          {section.title}
          <svg class="w-3 h-3 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <ul class="space-y-0.5 mt-2">
          {section.hasOverview && (
            <li>
              <a
                href={`/${overviewPath}`}
                class:list={[
                  "doc-link block rounded px-2 py-1",
                  { active: current === overviewPath },
                ]}
              >
                Overview
              </a>
            </li>
          )}
          {section.entries.map((e: any) => {
            const href = `${section.base}/${e.id}`;
            const active = current === href;
            return (
              <li>
                <a
                  href={`/${href}`}
                  class:list={["doc-link block rounded px-2 py-1", { active }]}
                >
                  {docLabel(e.id.replace("stdlib/", ""))}
                </a>
              </li>
            );
          })}
        </ul>
      </details>
      );
    })
  }
</nav>

<style>
  .doc-link {
    color: var(--text-muted);
    text-decoration: none;
  }
  .doc-link:hover {
    color: var(--text);
    background-color: var(--bg-soft);
  }
  .doc-link.active {
    color: var(--accent);
    background-color: var(--bg-soft);
    font-weight: 600;
  }
  
  /* Hide the default marker for summary elements */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
