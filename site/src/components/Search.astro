---
// Search popover — Pagefind-powered search in an overlay dialog
---

<button id="search-trigger" class="search-trigger" aria-label="Search" title="Search (Ctrl+K)">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"/>
    <path d="m21 21-4.35-4.35"/>
  </svg>
  <span class="search-trigger-label">Search</span>
  <kbd class="search-kbd">Ctrl+K</kbd>
</button>

<div id="search-overlay" class="search-overlay hidden" role="dialog" aria-modal="true" aria-label="Search">
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-panel">
    <div id="search" class="pagefind-custom-ui"></div>
  </div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  (() => {
    const trigger = document.getElementById("search-trigger");
    const overlay = document.getElementById("search-overlay");
    const backdrop = document.getElementById("search-backdrop");
    let pagefindInitialized = false;

    function openSearch() {
      if (!pagefindInitialized && window.PagefindUI) {
        new window.PagefindUI({
          element: "#search",
          showImages: false,
          showSubResults: true,
        });
        pagefindInitialized = true;
      }
      overlay.classList.remove("hidden");
      overlay.classList.add("open");
      document.body.style.overflow = "hidden";
      // Focus the input after a small delay for the animation
      setTimeout(() => {
        const input = overlay.querySelector(".pagefind-ui__search-input");
        if (input) input.focus();
      }, 150);
    }

    function closeSearch() {
      overlay.classList.add("hidden");
      overlay.classList.remove("open");
      document.body.style.overflow = "";
      trigger.focus();
    }

    // Open on trigger click
    trigger.addEventListener("click", openSearch);

    // Close on backdrop click
    backdrop.addEventListener("click", closeSearch);

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !overlay.classList.contains("hidden")) {
        closeSearch();
      }
    });

    // Open on Ctrl+K / Cmd+K
    document.addEventListener("keydown", (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === "k") {
        e.preventDefault();
        if (overlay.classList.contains("hidden")) {
          openSearch();
        } else {
          closeSearch();
        }
      }
    });

    // Close on result click (navigate away)
    overlay.addEventListener("click", (e) => {
      const link = e.target.closest(".pagefind-ui__result-link");
      if (link) {
        // Let the navigation happen naturally, then close
        setTimeout(closeSearch, 100);
      }
    });
  })();
</script>

<style is:global>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background-color: var(--bg-soft);
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.35rem 0.7rem;
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .search-trigger:hover {
    border-color: var(--accent);
    color: var(--text);
  }
  .search-trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .search-trigger-label {
    display: none;
  }
  @media (min-width: 640px) {
    .search-trigger-label {
      display: inline;
    }
  }
  .search-kbd {
    display: none;
    font-family: inherit;
    font-size: 0.65rem;
    padding: 0.1rem 0.3rem;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    color: var(--text-muted);
    background-color: var(--bg);
    line-height: 1.2;
  }
  @media (min-width: 640px) {
    .search-kbd {
      display: inline;
    }
  }

  /* Overlay backdrop */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 4rem 1rem 2rem;
  }
  .search-overlay.hidden {
    display: none;
  }
  .search-backdrop {
    position: absolute;
    inset: 0;
    background-color: color-mix(in srgb, var(--bg) 60%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .search-panel {
    position: relative;
    width: 100%;
    max-width: 42rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    box-shadow: 0 16px 48px color-mix(in srgb, #000 40%, transparent);
    padding: 1rem 1.25rem 0.5rem;
    animation: search-slide-in 0.15s ease-out;
  }
  @keyframes search-slide-in {
    from {
      opacity: 0;
      transform: translateY(-6px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .search-panel {
      animation: none;
    }
  }

  /* Pagefind UI overrides */
  .pagefind-custom-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--bg-soft);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-font: inherit;
    --pagefind-ui-result-font: inherit;
  }

  .pagefind-custom-ui .pagefind-ui__search-clear {
    display: none;
  }

  .pagefind-custom-ui .pagefind-ui__search-input {
    background-color: var(--bg-soft);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.7rem 1rem;
    font-size: 1rem;
  }
  .pagefind-custom-ui .pagefind-ui__search-input::placeholder {
    color: var(--text-muted);
  }
  .pagefind-custom-ui .pagefind-ui__search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .pagefind-custom-ui .pagefind-ui__search-input::-webkit-search-decoration,
  .pagefind-custom-ui .pagefind-ui__search-input::-webkit-search-cancel-button {
    display: none;
  }

  .pagefind-custom-ui .pagefind-ui__result {
    border-color: var(--border);
    padding: 0.6rem 0;
  }
  .pagefind-custom-ui .pagefind-ui__result-title {
    color: var(--text);
    font-weight: 600;
  }
  .pagefind-custom-ui .pagefind-ui__result-title a {
    color: var(--text);
    text-decoration: none;
  }
  .pagefind-custom-ui .pagefind-ui__result-title a:hover {
    color: var(--accent);
  }
  .pagefind-custom-ui .pagefind-ui__result-excerpt {
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
  .pagefind-custom-ui mark {
    background-color: color-mix(in srgb, var(--accent) 30%, transparent);
    color: var(--text);
  }

  .pagefind-custom-ui .pagefind-ui__message {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .pagefind-custom-ui .pagefind-ui__drawer {
    margin-top: 0.5rem;
  }

  .pagefind-custom-ui .pagefind-ui__button {
    background-color: var(--bg-soft);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    padding: 0.35rem 0.8rem;
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
  }
  .pagefind-custom-ui .pagefind-ui__button:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
