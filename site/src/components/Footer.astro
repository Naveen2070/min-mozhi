---
// Site-wide footer. Dual MIT + Apache-2.0 license linked to the repo's two LICENSE
// files (matches Cargo.toml `license = "MIT OR Apache-2.0"`).
import Mascot from "./Mascot.astro";

const REPO = "https://github.com/Naveen2070/min-mozhi";
const AUTHOR = "https://naveenr.in";
---

<footer class="bd fg-muted border-t py-8 text-sm">
  <div
    class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4"
  >
    <span class="inline-flex items-center gap-2">
      <Mascot class="h-9 w-9 shrink-0" alt="" />
      <span class="ff-tamil" lang="ta">மின்மொழி</span> — Speak in Circuits · © 2026
      Naveen R · Licensed under
      <a href={`${REPO}/blob/master/LICENSE-MIT`} class="fg">MIT</a>
      <span aria-hidden="true">+</span>
      <a href={`${REPO}/blob/master/LICENSE-APACHE`} class="fg">Apache-2.0</a>
    </span>
    <span>
      Made with <span class="fg-accent" aria-hidden="true">♥</span> by
      <a href={AUTHOR} class="fg">Naveen R</a> · Built in Tamil Nadu 🇮🇳
    </span>
  </div>
</footer>
