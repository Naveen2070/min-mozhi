---
// Site-wide footer. Dual MIT + Apache-2.0 license linked to the repo's two LICENSE
// files (matches Cargo.toml `license = "MIT OR Apache-2.0"`).
const REPO = "https://github.com/Naveen2070/min-mozhi";
const AUTHOR = "https://github.com/Naveen2070";
---

<footer
  class="border-t py-8 text-sm"
  style="border-color: var(--border); color: var(--text-muted)"
>
  <div
    class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4"
  >
    <span>
      <span style="font-family: var(--font-tamil)">மின்மொழி</span> — Speak in Circuits
      · © 2026 Naveen R · Licensed under
      <a href={`${REPO}/blob/master/LICENSE-MIT`} style="color: var(--text)"
        >MIT</a
      >
      <span aria-hidden="true">+</span>
      <a href={`${REPO}/blob/master/LICENSE-APACHE`} style="color: var(--text)"
        >Apache-2.0</a
      >
    </span>
    <span>
      Made with <span style="color: var(--accent)" aria-hidden="true">♥</span> by
      <a href={AUTHOR} style="color: var(--text)">Naveen R</a> · Built in Tamil Nadu
      🇮🇳
    </span>
  </div>
</footer>
