---
// The Min-Mozhi logo mark: a clock-edge (the signal an HDL describes) on a
// brand-blue tile. Font-free vector, so it stays crisp from a 16px favicon up,
// and matches /favicon.svg. Decorative — brand text accompanies it at each use.
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
// Unique gradient id per instance so multiple marks on one page stay valid.
const id = "lg-" + Math.random().toString(36).slice(2, 8);
---

<svg
  class={`shrink-0 ${className}`}
  viewBox="0 0 64 64"
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <linearGradient id={id} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#1e7fff"></stop>
      <stop offset="1" stop-color="#0a5fd6"></stop>
    </linearGradient>
  </defs>
  <rect x="2" y="2" width="60" height="60" rx="14" fill={`url(#${id})`}></rect>
  <path
    d="M11 40 H21 V24 H32 V40 H43 V24 H53"
    fill="none"
    stroke="#ffd60a"
    stroke-width="6.5"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
  <circle cx="53" cy="24" r="4" fill="#ffd60a"></circle>
</svg>
