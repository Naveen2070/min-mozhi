---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Min-Mozhi — a modern, safe-by-default HDL",
  description = "A modern, safe-by-default hardware description language — built to teach digital design, and the first Tamil-rooted HDL. Reads like Go/TypeScript, safe like Rust, speaks English, Tanglish, and Tamil.",
} = Astro.props;

// Absolute URLs for canonical + social cards. `Astro.site` is the configured
// production origin; falls back gracefully in dev where it may be undefined.
const site = Astro.site ?? new URL("https://mimz.naveenr.in");
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL("/og.png", site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Twitter cards -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Min-Mozhi" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Set the theme before paint to avoid a flash of the wrong colors. -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("theme");
        const dark = saved ? saved === "dark" : true; // dark-first default
        document.documentElement.classList.toggle("dark", dark);
      })();
    </script>

    <!-- Fonts are self-hosted via Fontsource (imported in global.css) — no
         third-party font request, so no preconnect/stylesheet link here. -->
  </head>
  <body>
    <slot />
  </body>
</html>
