{
  "name": "mimz",
  "displayName": "Min-Mozhi (மின்மொழி)",
  "description": "Min-Mozhi .mimz language support — trilingual syntax highlighting plus live compiler diagnostics via `mimz lsp`.",
  "version": "0.3.0",
  "publisher": "min-mozhi",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Naveen2070/min-mozhi.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/Naveen2070/min-mozhi/issues"
  },
  "homepage": "https://github.com/Naveen2070/min-mozhi#readme",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:mimz"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mimz",
        "aliases": [
          "Min-Mozhi",
          "mimz"
        ],
        "extensions": [
          ".mimz"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mimz",
        "scopeName": "source.mimz",
        "path": "./syntaxes/mimz.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Min-Mozhi",
      "properties": {
        "mimz.serverPath": {
          "type": "string",
          "default": "mimz",
          "description": "Path to the mimz compiler binary (the language server is `mimz lsp`). Default assumes mimz is on PATH."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  },
  "scripts": {
    "package": "vsce package"
  }
}
