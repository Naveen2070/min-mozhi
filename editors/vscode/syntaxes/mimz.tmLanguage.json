{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Min-Mozhi",
  "scopeName": "source.mimz",
  "comment": "All three keyword flavors (English, Tanglish, Tamil) highlight identically Рђћ spellings must stay in sync with keywords.toml; tests/grammar_sync.rs enforces it. Custom (?<![\\p{L}\\p{N}_]) boundaries are used instead of \\b so Tamil-script keywords match correctly.",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#module-declaration" },
    { "include": "#enum-declaration" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-control" },
    { "include": "#keywords-constant" },
    { "include": "#keywords-logical-words" },
    { "include": "#reserved-words" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.mimz", "match": "//.*$" },
        { "name": "comment.block.mimz", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.mimz",
      "begin": "\"",
      "end": "\""
    },
    "module-declaration": {
      "comment": "module / thoguthi / Я«цЯ»іЯ«ЋЯ»ЂЯ«цЯ«┐ followed by the module name",
      "match": "(?<![\\p{L}\\p{N}_])(module|thoguthi|Я«цЯ»іЯ«ЋЯ»ЂЯ«цЯ«┐)(?![\\p{L}\\p{N}_])\\s+([\\p{L}_][\\p{L}\\p{N}_]*)",
      "captures": {
        "1": { "name": "storage.type.module.mimz" },
        "2": { "name": "entity.name.type.module.mimz" }
      }
    },
    "enum-declaration": {
      "comment": "enum / vagai / Я«хЯ«ЋЯ»ѕ followed by the enum name",
      "match": "(?<![\\p{L}\\p{N}_])(enum|vagai|Я«хЯ«ЋЯ»ѕ)(?![\\p{L}\\p{N}_])\\s+([\\p{L}_][\\p{L}\\p{N}_]*)",
      "captures": {
        "1": { "name": "storage.type.enum.mimz" },
        "2": { "name": "entity.name.type.enum.mimz" }
      }
    },
    "keywords-declaration": {
      "comment": "declaration keywords, all flavors (incl. the `include` alias of import)",
      "name": "storage.type.mimz",
      "match": "(?<![\\p{L}\\p{N}_])(module|thoguthi|Я«цЯ»іЯ«ЋЯ»ЂЯ«цЯ«┐|in|ulle|Я«ЅЯ«│Я»Ї|out|veli|Я«хЯ»єЯ«│Я«┐|wire|kambi|Я«ЋЯ««Я»ЇЯ«фЯ«┐|reg|nilai|Я«еЯ«┐Я«▓Я»ѕ|clock|kadigaram|Я«ЋЯ«ЪЯ«┐Я«ЋЯ«ЙЯ«░Я««Я»Ї|reset|meetamai|Я««Я»ђЯ«ЪЯ»ЇЯ«ЪЯ««Я»ѕ|enum|vagai|Я«хЯ«ЋЯ»ѕ|let|vai|Я«хЯ»ѕ|const|maara|Я««Я«ЙЯ«▒Я«Й|import|include|serkka|Я«џЯ»ЄЯ«░Я»ЇЯ«ЋЯ»ЇЯ«Ћ|test|sodhanai|Я«џЯ»ІЯ«цЯ«ЕЯ»ѕ|for|kaaga|Я«ЋЯ»ЇЯ«ЋЯ«ЙЯ«Ћ|tick|thattu|Я«цЯ«ЪЯ»ЇЯ«ЪЯ»Ђ|expect|ethirpaar|Я«јЯ«цЯ«┐Я«░Я»ЇЯ«фЯ«ЙЯ«░Я»Ї)(?![\\p{L}\\p{N}_])"
    },
    "keywords-control": {
      "comment": "control-flow keywords, all flavors",
      "name": "keyword.control.mimz",
      "match": "(?<![\\p{L}\\p{N}_])(if|endral|Я«јЯ«ЕЯ»ЇЯ«▒Я«ЙЯ«▓Я»Ї|else|illaiyel|Я«ЄЯ«▓Я»ЇЯ«▓Я»ѕЯ«»Я»ЄЯ«▓Я»Ї|match|poruthu|Я«фЯ»іЯ«░Я»ЂЯ«цЯ»ЇЯ«цЯ»Ђ|on|pothu|Я«фЯ»ІЯ«цЯ»Ђ|rise|yetram|Я«ЈЯ«▒Я»ЇЯ«▒Я««Я»Ї|repeat|meendum|Я««Я»ђЯ«БЯ»ЇЯ«ЪЯ»ЂЯ««Я»Ї)(?![\\p{L}\\p{N}_])"
    },
    "keywords-constant": {
      "name": "constant.language.mimz",
      "match": "(?<![\\p{L}\\p{N}_])(true|unmai|Я«ЅЯ«БЯ»ЇЯ««Я»ѕ|false|poi|Я«фЯ»іЯ«»Я»Ї)(?![\\p{L}\\p{N}_])"
    },
    "keywords-logical-words": {
      "comment": "word aliases of && || ! (G1-x)",
      "name": "keyword.operator.logical.mimz",
      "match": "(?<![\\p{L}\\p{N}_])(and|mattrum|Я««Я«▒Я»ЇЯ«▒Я»ЂЯ««Я»Ї|or|alladhu|Я«ЁЯ«▓Я»ЇЯ«▓Я«цЯ»Ђ|not|illa|Я«ЄЯ«▓Я»ЇЯ«▓Я«Й)(?![\\p{L}\\p{N}_])"
    },
    "reserved-words": {
      "comment": "reserved for future features Рђћ using them is a compile error",
      "name": "invalid.illegal.reserved.mimz",
      "match": "(?<![\\p{L}\\p{N}_])(fall|syntax|ilakkanam|Я«ЄЯ«▓Я«ЋЯ»ЇЯ«ЋЯ«БЯ««Я»Ї|mem|sync|inout|struct)(?![\\p{L}\\p{N}_])"
    },
    "types": {
      "comment": "universal vocabulary Рђћ never translated",
      "name": "support.type.mimz",
      "match": "(?<![\\p{L}\\p{N}_])(bit|bits|signed|int|bool)(?![\\p{L}\\p{N}_])"
    },
    "builtins": {
      "comment": "the complete builtin list; only callables in the language",
      "name": "support.function.builtin.mimz",
      "match": "(?<![\\p{L}\\p{N}_])(extend|trunc|signed|unsigned)(?=\\()"
    },
    "numbers": {
      "name": "constant.numeric.mimz",
      "match": "(?<![\\p{L}\\p{N}_])(0[bB][01_]+|0[xX][0-9a-fA-F_]+|[0-9][0-9_]*)(?![\\p{L}\\p{N}_])"
    },
    "operators": {
      "patterns": [
        {
          "comment": "wrapping arithmetic Рђћ the visible-overflow operators",
          "name": "keyword.operator.arithmetic.wrapping.mimz",
          "match": "\\+%|-%|\\*%"
        },
        {
          "comment": "register assignment",
          "name": "keyword.operator.assignment.reg.mimz",
          "match": "<-"
        },
        {
          "name": "keyword.operator.arrow.mimz",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.mimz",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.mimz",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.mimz",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.arithmetic.mimz",
          "match": "\\+|-|\\*"
        },
        {
          "name": "keyword.operator.assignment.mimz",
          "match": "="
        }
      ]
    }
  }
}
