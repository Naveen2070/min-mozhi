# Rust
/target/
**/*.rs.bk
**/target/

# Generated outputs (compiler artifacts during development)
/build/
*.v.out
*.vcd
# …but the byte-for-byte VCD golden fixtures ARE tracked
!tests/golden/*.vcd

# IDE / editor
/.vscode/
/.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Session/agent scratch (not project history)
/.remember/
/.claude/

# Generated knowledge graph (graphify tool output)
/graphify-out/


# Added by cargo

/target

# VS Code extension build artifacts (the .vsix IS committed; deps are not)
editors/vscode/node_modules/
editors/vscode/package-lock.json

# Packaged extension binaries (rebuild with `npx @vscode/vsce package`)
editors/vscode/*.vsix

# Benchmark outputs (regenerate with `cargo run --release --bin mimz-bench`)
bench-report.html
bench-report.json

# wasm-pack / wasm-bindgen output for the browser playground (regenerate with
# `wasm-pack build crates/mimz-wasm --target web`)
crates/mimz-wasm/pkg/

# serena
.serena

# misc
.venv
